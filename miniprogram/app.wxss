page {
  background: #f4fff6;
  color: #1a2e22;
  font-size: 28rpx;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(43, 182, 115, 0.12);
}

.btn-main {
  background: linear-gradient(135deg, #ff8c42 0%, #ff6b1a 100%);
  color: #fff;
  border-radius: 999rpx;
  padding: 22rpx 48rpx;
  font-weight: 600;
  border: none;
}

.btn-green {
  background: linear-gradient(135deg, #2bb673 0%, #1d8a5a 100%);
  color: #fff;
  border-radius: 999rpx;
  padding: 22rpx 48rpx;
  font-weight: 600;
  border: none;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  background: rgba(43, 182, 115, 0.15);
  color: #1d8a5a;
}

.title-lg {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f2918;
}

.sub {
  color: #6b7c72;
  font-size: 24rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mt-16 {
  margin-top: 16rpx;
}

.mb-16 {
  margin-bottom: 16rpx;
}
