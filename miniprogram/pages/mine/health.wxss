.page {
  height: 100vh;
  padding-bottom: 40rpx;
}

.row-line {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
}

.val {
  font-weight: 700;
  color: #ff7a00;
}

.input {
  border: 1rpx solid #d1fae5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  background: #fff;
}

.link {
  margin-top: 20rpx;
  color: #2bb673;
  font-weight: 600;
}

.mt-16 {
  margin-top: 16rpx;
}

.btn-block {
  margin-top: 24rpx;
  width: 100%;
}
