.page {
  height: 100vh;
}

.hero {
  background: linear-gradient(160deg, #2bb673 0%, #1d8a5a 45%, #ff8c42 160%);
  padding: 48rpx 32rpx 56rpx;
  color: #fff;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
}

.hero-sub {
  margin-top: 12rpx;
  opacity: 0.95;
  font-size: 28rpx;
}

.ann-item {
  border-bottom: 1rpx solid #e8f5ee;
  padding: 20rpx 0;
}

.ann-item:last-child {
  border-bottom: none;
}

.ann-title {
  font-weight: 600;
  color: #0f2918;
}

.ann-content {
  margin-top: 8rpx;
}

.ann-date {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.link-more {
  color: #ff7a00;
  font-size: 26rpx;
}

.course-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0fdf4;
}

.course-row:last-child {
  border-bottom: none;
}

.c-name {
  font-weight: 600;
  font-size: 30rpx;
}

.quick {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx 48rpx;
}

.q-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #374151;
}

.q-icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #fff 0%, #e8fcef 100%);
  color: #2bb673;
  font-weight: 800;
  margin-bottom: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(43, 182, 115, 0.2);
}

.mt-8 {
  margin-top: 8rpx;
}
