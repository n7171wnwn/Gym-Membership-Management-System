.page-pad {
  padding: 48rpx 36rpx;
}

.logo-area {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 800;
  color: #2bb673;
}

.hint {
  margin: 16rpx 0 32rpx;
  text-align: center;
}

.divider {
  margin: 40rpx 0 24rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.input {
  border: 1rpx solid #d1fae5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: #fff;
}

.btn-line {
  background: #fff;
  color: #2bb673;
  border: 2rpx solid #2bb673;
  border-radius: 999rpx;
  padding: 22rpx;
  margin-top: 16rpx;
}
