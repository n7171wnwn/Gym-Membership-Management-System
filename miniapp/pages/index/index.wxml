<view class="card">
  <view style="font-weight:600;margin-bottom:8px;">公告</view>
  <block wx:for="{{list}}" wx:key="date">
    <view style="padding:8px 0;border-bottom:1px solid #eef2f7;">
      <view style="font-weight:600;">{{item.title}}</view>
      <view style="color:#64748b;font-size:12px;margin:4px 0;">{{item.date}}</view>
      <view style="color:#334155;">{{item.content}}</view>
    </view>
  </block>
  <button class="btn" type="primary" bindtap="goLogin">绑定手机号登录</button>
</view>

